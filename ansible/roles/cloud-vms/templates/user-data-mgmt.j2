#cloud-config
hostname: mgmt

users:
  - name: darthv
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - {{ ssh_public_key }}

package_update: true
packages:
  - qemu-guest-agent
  - openssh-server
  - git
  - ansible
  - python3
  - python3-pip
  - curl
  - vim

runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent

